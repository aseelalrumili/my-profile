{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd Frontend/portfolio-app && npm install && npm run build",
  "outputDirectory": "Frontend/portfolio-app/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://profile-aseel.netlify.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://profile-aseel.netlify.app/uploads/:path*" },
    { "source": "/((?!api|uploads|assets|favicon\\.ico|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
